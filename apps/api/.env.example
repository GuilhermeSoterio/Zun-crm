# ── Banco de dados (Railway fornece automaticamente) ──────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/reativa

# ── Redis (Railway fornece automaticamente) ───────────────────────────────────
REDIS_URL=redis://default:password@host:6379

# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=3003
NODE_ENV=production

# ── Autenticação (gere uma string aleatória >= 32 chars) ──────────────────────
# Gerar: openssl rand -hex 32
JWT_SECRET=coloque-uma-string-secreta-de-pelo-menos-32-caracteres-aqui

# ── Criptografia de dados (gere 32 bytes em hex = 64 chars) ──────────────────
# Gerar: openssl rand -hex 32
ENCRYPTION_MASTER_KEY=coloque-64-caracteres-hex-aqui-ex-8b05ac92583405b7aa2e4658a6dbddc1

# ── WhatsApp via Evolution API ────────────────────────────────────────────────
EVOLUTION_API_URL=https://sua-evolution-api.com
EVOLUTION_API_KEY=sua-chave-da-evolution-api

# ── URL pública da API (usada pelo webhook do Evolution) ─────────────────────
WEBHOOK_BASE_URL=https://sua-api.railway.app

# ── Anthropic (IA para classificar respostas) ─────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Cloudflare R2 (upload de CSV — opcional) ─────────────────────────────────
# Se não configurar, o import de CSV não funcionará
CLOUDFLARE_R2_ENDPOINT=https://account.r2.cloudflarestorage.com
CLOUDFLARE_R2_ACCESS_KEY=
CLOUDFLARE_R2_SECRET_KEY=
CLOUDFLARE_R2_BUCKET=reativa-imports
